# Copy to .env. Never commit .env.
# Variáveis marcadas (REQUIRED em prod) são obrigatórias quando DJANGO_DEBUG=false.

# === Postgres ===
# POSTGRES_* configura o container; DJANGO_DB_* sobrescreve a conexão da app.
# Em prod, use DJANGO_DB_USER=pentesthub_app (criado pela migration accounts/0002)
# para que o RLS enforce — owner do banco bypassa RLS.
POSTGRES_USER=pentesthub
POSTGRES_PASSWORD=devpass                 # (REQUIRED em prod, troque)
POSTGRES_DB=pentesthub
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# DJANGO_DB_USER=pentesthub_app           # (recomendado em prod)
# DJANGO_DB_PASSWORD=...                  # senha do role de runtime

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === MinIO (S3 local em dev) — em prod, S3 + IAM role ===
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=pentesthub-dev                  # (REQUIRED em prod)
S3_ACCESS_KEY=minioadmin                  # (REQUIRED em prod)
S3_SECRET_KEY=minioadmin                  # (REQUIRED em prod)

# === E-mail (MailHog em dev; SMTP real em prod) ===
EMAIL_HOST=mailhog                        # (REQUIRED em prod)
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=false                       # true em prod
EMAIL_FROM=no-reply@pentesthub.local      # (REQUIRED em prod)

# === Django ===
# DJANGO_SECRET_KEY: (REQUIRED em prod). Gere com:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=dev-only-not-for-production-please-rotate
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://web:3000
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://web:3000

# === MFA (cifragem at-rest do mfa_secret) ===
# (REQUIRED em prod). Gere com:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MFA_ENCRYPTION_KEY=

# === KMS (DEV LOCAL — em prod, AWS KMS substitui) ===
LOCAL_KMS_MASTER_KEY=ZGV2LW9ubHktbWFzdGVyLWtleS1kby1ub3QtdXNlLWluLXByb2Q=

# === PSP fake (em prod, Pagar.me/Asaas) ===
PSP=fake                                  # (REQUIRED em prod: pagarme | asaas)
PSP_WEBHOOK_SECRET=dev-shared-secret      # (REQUIRED em prod)

# === Admin inicial (lido por `manage.py create_admin`) ===
# Não use valores óbvios. Senha ≥12 chars, sem padrões fracos.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Operações AegisHub

# === Next.js / BFF ===
NEXT_PUBLIC_APP_NAME=PentestHub
API_INTERNAL_URL=http://api:8000
NEXTAUTH_URL=http://localhost:3000
