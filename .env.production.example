# ============================================================================
# AegisHub — variáveis de PRODUÇÃO
# Copie para `.env.production` e preencha. NUNCA faça commit do .env.production.
# Use o stack: docker compose -f docker-compose.prod.yml --env-file .env.production ...
# ============================================================================

# --- Domínio público (Caddy emite TLS Let's Encrypt para ele) ---
# O DNS A/AAAA deste domínio precisa apontar para o IP do servidor ANTES de subir.
APP_DOMAIN=app.seudominio.com.br

# --- Postgres (owner: roda migrations, BYPASSRLS) ---
POSTGRES_USER=pentesthub
POSTGRES_PASSWORD=TROQUE-senha-forte-do-owner
POSTGRES_DB=pentesthub
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# 'disable' para o Postgres embarcado (rede docker privada do host).
# Use 'require' se apontar para um Postgres gerenciado/externo (RDS etc).
DJANGO_DB_SSLMODE=disable

# --- Senha da role de runtime (pentesthub_app, NOBYPASSRLS, RLS enforce) ---
# Diferente da senha do owner. DJANGO_DB_USER é fixado em pentesthub_app no compose.
DJANGO_DB_PASSWORD=TROQUE-senha-forte-do-app-role

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Django ---
DJANGO_DEBUG=false
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=TROQUE-chave-longa-aleatoria-64-bytes
# Hosts/origins que a API aceita. Inclua o domínio público e o nome interno 'api'.
DJANGO_ALLOWED_HOSTS=app.seudominio.com.br,api
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.seudominio.com.br
DJANGO_CORS_ALLOWED_ORIGINS=https://app.seudominio.com.br

# --- Admin inicial (provisionado no boot, idempotente) ---
ADMIN_EMAIL=ops@seudominio.com.br
ADMIN_PASSWORD=TROQUE-senha-admin-forte
ADMIN_NAME=Operações AegisHub

# --- E-mail (SMTP real — ex.: Amazon SES, Resend, SendGrid) ---
EMAIL_HOST=smtp.seuprovedor.com
EMAIL_PORT=587
EMAIL_HOST_USER=TROQUE
EMAIL_HOST_PASSWORD=TROQUE
EMAIL_USE_TLS=true
EMAIL_FROM=no-reply@seudominio.com.br
FRONTEND_URL=https://app.seudominio.com.br

# --- Storage S3 (MinIO embarcado no compose, ou troque por AWS S3) ---
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=aegishub-prod
S3_ACCESS_KEY=TROQUE-access-key
S3_SECRET_KEY=TROQUE-secret-key

# --- Criptografia ---
# KEK local. Em prod sério, migrar para AWS KMS. base64 de 32 bytes:
# python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
LOCAL_KMS_MASTER_KEY=TROQUE-base64-32-bytes
# Fernet key para cifrar mfa_secret at-rest:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MFA_ENCRYPTION_KEY=TROQUE-fernet-key

# --- PSP (gateway de pagamento). Fase 1 não usa; manter 'fake' por ora. ---
PSP=fake
PSP_WEBHOOK_SECRET=TROQUE-segredo-webhook

# --- Next.js / BFF (server-side, interno) ---
API_INTERNAL_URL=http://api:8000
NEXT_PUBLIC_APP_NAME=AegisHub
