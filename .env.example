# Copy to .env. Never commit .env.

# === Postgres ===
POSTGRES_USER=pentesthub
POSTGRES_PASSWORD=devpass
POSTGRES_DB=pentesthub
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === MinIO (S3 local) ===
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=pentesthub-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# === E-mail (MailHog) ===
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_FROM=no-reply@pentesthub.local

# === Django ===
DJANGO_SECRET_KEY=dev-only-not-for-production-please-rotate
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://web:3000
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://web:3000

# === KMS (DEV LOCAL — NÃO USE EM PROD) ===
# Chave fixa em base64. Em produção, este valor é substituído por AWS KMS.
LOCAL_KMS_MASTER_KEY=ZGV2LW9ubHktbWFzdGVyLWtleS1kby1ub3QtdXNlLWluLXByb2Q=

# === PSP fake ===
PSP=fake
PSP_WEBHOOK_SECRET=dev-shared-secret

# === Next.js / BFF ===
NEXT_PUBLIC_APP_NAME=PentestHub
API_INTERNAL_URL=http://api:8000
NEXTAUTH_URL=http://localhost:3000
